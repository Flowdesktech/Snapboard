<Window x:Class="Snapboard.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:Snapboard.Controls"
        Title="Snapboard — Settings"
        Icon="Assets/snapboard.ico"
        Width="640" Height="720"
        MinWidth="520" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#FF15171C"
        Foreground="#FFE6E8EC"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBg"     Color="#FF1C1F26"/>
        <SolidColorBrush x:Key="CardBorder" Color="#FF2A2E37"/>
        <SolidColorBrush x:Key="Muted"      Color="#FF9BA1AD"/>
        <SolidColorBrush x:Key="Accent"     Color="#FF3DA9FC"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF5BB8FD"/>
        <SolidColorBrush x:Key="InputBg"    Color="#FF0F1116"/>
        <SolidColorBrush x:Key="InputBgHover" Color="#FF131722"/>
        <SolidColorBrush x:Key="InputBorder" Color="#FF2E3340"/>
        <SolidColorBrush x:Key="InputBorderHover" Color="#FF414858"/>
        <SolidColorBrush x:Key="InputBorderFocus" Color="#FF3DA9FC"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="Field" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- Inline error under a HotkeyBox when Save reveals an OS conflict.
             Hidden by default; SettingsWindow.xaml.cs flips Visibility to
             Visible and fills Text for each hotkey that failed to register. -->
        <Style x:Key="FieldError" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0556B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE6E8EC"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FFE6E8EC"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TextInput" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="#FFEAF0F8"/>
            <Setter Property="CaretBrush" Value="#FFEAF0F8"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource InputBgHover}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource InputBorderHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource InputBorderFocus}"/>
                                <Setter Property="Background" Value="#FF141B2A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type c:HotkeyBox}" BasedOn="{StaticResource TextInput}">
            <Setter Property="FontFamily" Value="Cascadia Mono"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="11,7"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="24,22,24,10">
            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Configure hotkeys, capture behavior and output formats."
                       Foreground="{StaticResource Muted}" FontSize="13" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,4,24,4">
            <StackPanel>

                <!-- Hotkey conflict alert banner. Collapsed by default; shown by
                     SettingsWindow.xaml.cs when Save fails due to an OS-level
                     hotkey conflict. -->
                <Border x:Name="HotkeyErrorBanner"
                        Background="#33E0556B"
                        BorderBrush="#FFE0556B"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚠"
                                   Foreground="#FFE0556B"
                                   FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Top"
                                   Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Hotkey already in use"
                                       Foreground="#FFE0556B" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock x:Name="HotkeyErrorBannerText"
                                       Foreground="#FFE6E8EC" FontSize="12" TextWrapping="Wrap"
                                       Margin="0,2,0,0"
                                       Text="One or more hotkeys couldn't be registered because another app owns them. Pick a different combination for the highlighted field(s) below and try Save again."/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- HOTKEYS -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="HOTKEYS"/>

                        <TextBlock Style="{StaticResource Field}" Text="Capture region (opens the selection overlay)"/>
                        <c:HotkeyBox x:Name="CaptureHotkeyBox" Hotkey="{Binding CaptureHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="CaptureHotkeyError"     Style="{StaticResource FieldError}"/>

                        <TextBlock Style="{StaticResource Field}" Text="Instant full-screen save" Margin="0,14,0,2"/>
                        <c:HotkeyBox x:Name="FullScreenHotkeyBox" Hotkey="{Binding InstantFullScreenHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="FullScreenHotkeyError"  Style="{StaticResource FieldError}"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Captures the primary monitor and saves it immediately (no editor) to your save directory."/>

                        <TextBlock Style="{StaticResource Field}" Text="Color picker" Margin="0,14,0,2"/>
                        <c:HotkeyBox x:Name="ColorPickerHotkeyBox" Hotkey="{Binding ColorPickerHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="ColorPickerHotkeyError" Style="{StaticResource FieldError}"/>

                        <TextBlock Style="{StaticResource Field}" Text="OCR on selection" Margin="0,14,0,2"/>
                        <c:HotkeyBox x:Name="OcrHotkeyBox" Hotkey="{Binding OcrHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="OcrHotkeyError"         Style="{StaticResource FieldError}"/>

                        <TextBlock Style="{StaticResource Field}" Text="Scan QR code" Margin="0,14,0,2"/>
                        <c:HotkeyBox x:Name="QrHotkeyBox" Hotkey="{Binding QrHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="QrHotkeyError"          Style="{StaticResource FieldError}"/>

                        <TextBlock Style="{StaticResource Field}" Text="Pixel ruler" Margin="0,14,0,2"/>
                        <c:HotkeyBox x:Name="PixelRulerHotkeyBox" Hotkey="{Binding PixelRulerHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock x:Name="PixelRulerHotkeyError"  Style="{StaticResource FieldError}"/>

                        <TextBlock Style="{StaticResource Hint}" Margin="0,10,0,0"
                                   Text="Click a field and press the key combination. Press Delete/Backspace to clear, Esc to cancel."/>
                    </StackPanel>
                </Border>

                <!-- CAPTURE BEHAVIOR -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="CAPTURE"/>
                        <CheckBox x:Name="CaptureCursorCheck"
                                  IsChecked="{Binding CaptureCursor, Mode=TwoWay}"
                                  Content="Include the mouse cursor in screenshots"/>
                        <CheckBox x:Name="TrayClickCapturesCheck"
                                  IsChecked="{Binding TrayClickCaptures, Mode=TwoWay}"
                                  Content="Clicking the tray icon starts a capture"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="When off, clicking the tray icon opens the Snapboard window instead."/>
                    </StackPanel>
                </Border>

                <!-- STARTUP -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="STARTUP"/>
                        <CheckBox x:Name="RunOnStartupCheck"
                                  IsChecked="{Binding RunOnStartup, Mode=TwoWay}"
                                  Content="Launch Snapboard when I sign in to Windows"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Auto-started Snapboard boots straight to the tray (no dashboard window) so your capture hotkey is immediately available. Registered per-user under HKCU\...\Run — no admin rights required."/>
                    </StackPanel>
                </Border>

                <!-- UPDATES -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="UPDATES"/>
                        <CheckBox x:Name="AutoCheckUpdatesCheck"
                                  IsChecked="{Binding AutoCheckUpdates, Mode=TwoWay}"
                                  Content="Check for updates automatically (daily)"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Snapboard contacts github.com once a day to check for a newer release. No telemetry is sent — just an unauthenticated GET to the public Releases API. You'll be asked before any download."/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="CheckUpdatesButton"
                                    Style="{StaticResource GhostButton}"
                                    Content="Check for updates now"
                                    Click="OnCheckUpdatesClick"/>
                            <TextBlock x:Name="UpdateStatusText"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="#FF9BA1AD"
                                       FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- OUTPUT -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="OUTPUT"/>

                        <TextBlock Style="{StaticResource Field}" Text="Default format" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="FormatPng"  GroupName="fmt" Content="PNG (lossless)"/>
                            <RadioButton x:Name="FormatJpeg" GroupName="fmt" Content="JPEG (smaller)"/>
                        </StackPanel>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="JPEG quality" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Slider Grid.Column="1" x:Name="JpegQualitySlider"
                                    Minimum="50" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"
                                    Value="{Binding JpegQuality, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Value, ElementName=JpegQualitySlider, StringFormat={}{0:0}}"
                                       VerticalAlignment="Center" Margin="10,0,0,0" Width="28" TextAlignment="Right"/>
                        </Grid>

                        <TextBlock Style="{StaticResource Field}" Text="Save directory" Margin="0,14,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource TextInput}"
                                     Text="{Binding SaveDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                    Content="Browse…" Margin="8,0,0,0" Click="OnBrowseFolderClick"/>
                        </Grid>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Used by instant full-screen saves and by auto-save. Leave empty to use Pictures\Snapboard."/>

                        <CheckBox x:Name="AutoSaveCheck"
                                  IsChecked="{Binding AutoSaveAfterCapture, Mode=TwoWay}"
                                  Content="Auto-save after capture (skip the file dialog in the editor)"
                                  Margin="0,14,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Advanced / file location -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionLabel}" Text="STORAGE"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   x:Name="SettingsPathText"
                                   FontFamily="Consolas"/>
                        <Button Style="{StaticResource GhostButton}"
                                Content="Open settings folder" Click="OnOpenSettingsFolderClick"
                                HorizontalAlignment="Left" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#FF12141A"
                BorderBrush="{StaticResource CardBorder}" BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText"
                           Foreground="{StaticResource Muted}" FontSize="12"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButton}" Content="Cancel" Click="OnCancelClick" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Save" Click="OnSaveClick"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
