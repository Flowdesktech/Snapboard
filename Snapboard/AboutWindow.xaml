<Window x:Class="Snapboard.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Snapboard"
        Icon="Assets/snapboard.ico"
        Width="560" Height="620"
        MinWidth="520" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FF15171C"
        Foreground="#FFE6E8EC"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#FF1C1F26"/>
        <SolidColorBrush x:Key="CardBorder" Color="#FF2A2E37"/>
        <SolidColorBrush x:Key="Muted" Color="#FF9BA1AD"/>
        <SolidColorBrush x:Key="Accent" Color="#FF3DA9FC"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF5BB8FD"/>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="TextDecorations" Value="None"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentHover}"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ================ Dark ScrollBar ================ -->
        <!-- WPF's default ScrollBar template renders a light "classic" chrome,
             so we replace the Thumb, track and PageUp/PageDown buttons with
             a flat dark-on-dark look that matches the rest of the app. -->
        <Style x:Key="DarkScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd"
                                Background="#FF3A3F4A"
                                CornerRadius="3"
                                Margin="2"
                                SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF525867"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF6B7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource DarkScrollPageButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource DarkScrollPageButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="MinWidth" Value="10"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="MinHeight" Value="10"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Hero -->
        <Border Grid.Row="0" Padding="28,28,28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="Assets/snapboard.ico"
                       Width="56" Height="56"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,0,18,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Snapboard" FontSize="26" FontWeight="SemiBold"/>
                    <TextBlock x:Name="VersionText"
                               Text="Version 0.1"
                               Foreground="{StaticResource Muted}"
                               FontSize="12" Margin="0,2,0,0"/>
                    <TextBlock Text="Capture · Annotate · Blur · OCR · Color pick · Measure"
                               Foreground="{StaticResource Muted}"
                               FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" Margin="28,0,28,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Why -->
                <Border Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="WHY WE BUILT SNAPBOARD"/>

                        <TextBlock Foreground="#FFE6E8EC" FontSize="13" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,10">
                            Every modern Windows screenshot tool leans one way or the other — lightweight but
                            feature-starved, or powerful but cluttered and noisy. Most also ship a cloud
                            uploader bolted to the product, even for users who only ever use the local
                            capture feature.
                        </TextBlock>

                        <TextBlock Foreground="#FFE6E8EC" FontSize="13" TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,10">
                            Snapboard is the middle ground we wanted for our own day-to-day work:
                            a single, privacy-first tray app that bundles the six tools we reach for
                            most — region capture, annotation, a real blur tool for passwords &amp; tokens,
                            on-screen OCR, a color picker, and a PicPick-style pixel ruler — with a
                            native dark theme and keyboard-first UX.
                        </TextBlock>

                        <TextBlock Foreground="#FFE6E8EC" FontSize="13" TextWrapping="Wrap" LineHeight="20">
                            No accounts, no uploads, no telemetry. Everything stays on your machine.
                            It's open source and MIT-licensed so you (and we) can audit it, fork it,
                            and keep extending it — whiteboard mode, pinned screenshots, and more
                            are on the roadmap.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Credits -->
                <Border Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="DEVELOPED BY"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="FlowDesk"
                                       Foreground="#FFE6E8EC"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="·"
                                       Foreground="{StaticResource Muted}"
                                       Margin="8,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" FontSize="13">
                                <Hyperlink NavigateUri="https://flowdesk.tech"
                                           RequestNavigate="OnHyperlinkClick">flowdesk.tech</Hyperlink>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Foreground="{StaticResource Muted}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10">
                            Need a developer for your business idea? We take on contract and
                            product work — get in touch below.
                        </TextBlock>

                        <Grid Margin="0,4,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Website"
                                       Foreground="{StaticResource Muted}" FontSize="12" Margin="0,3,16,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" Margin="0,3">
                                <Hyperlink NavigateUri="https://flowdesk.tech"
                                           RequestNavigate="OnHyperlinkClick">https://flowdesk.tech</Hyperlink>
                            </TextBlock>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Contact"
                                       Foreground="{StaticResource Muted}" FontSize="12" Margin="0,3,16,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Margin="0,3">
                                <Hyperlink NavigateUri="mailto:contact@flowdesk.tech"
                                           RequestNavigate="OnHyperlinkClick">contact@flowdesk.tech</Hyperlink>
                            </TextBlock>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="License"
                                       Foreground="{StaticResource Muted}" FontSize="12" Margin="0,3,16,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12" Foreground="#FFE6E8EC" Margin="0,3"
                                       Text="MIT — free for personal and commercial use"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Built with -->
                <Border Background="{StaticResource CardBg}"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="BUILT WITH"/>
                        <TextBlock Foreground="#FFE6E8EC" FontSize="12" TextWrapping="Wrap" LineHeight="18"
                                   Text="C# · .NET 10 · WPF · Windows.Media.Ocr · GDI+ · DWM · Segoe Fluent Icons"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="#FF12141A"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0"
                Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Foreground="{StaticResource Muted}"
                           FontSize="12"
                           VerticalAlignment="Center">
                    <Run Text="© 2026 "/><Hyperlink NavigateUri="https://flowdesk.tech"
                                                    RequestNavigate="OnHyperlinkClick">FlowDesk</Hyperlink><Run Text=" · All rights reserved"/>
                </TextBlock>

                <Button Grid.Column="1"
                        Style="{StaticResource GhostButton}"
                        Content="Close"
                        Click="OnCloseClick"
                        IsCancel="True"
                        IsDefault="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
