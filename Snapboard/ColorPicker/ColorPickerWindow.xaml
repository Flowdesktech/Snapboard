<Window x:Class="Snapboard.ColorPicker.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapboard Color Picker"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="None"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="OnKeyDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseRightButtonDown="OnMouseRightButtonDown"
        Loaded="OnLoaded">
    <Grid x:Name="RootGrid" ClipToBounds="True">
        <Image x:Name="BackgroundImage" Stretch="Fill" SnapsToDevicePixels="True"/>

        <!-- Dim veil (faint) so user knows it's a picker mode -->
        <Rectangle Fill="#22000000" IsHitTestVisible="False"/>

        <!-- Top-center status chip -->
        <Border Background="#EE12141A" CornerRadius="6" Padding="12,6"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,18,0,0" IsHitTestVisible="False"
                BorderBrush="#FF3DA9FC" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎨" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Click to copy color" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="   ·   " Foreground="#FF9BA1AD" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="Right-click to change format" Foreground="#FF9BA1AD" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="   ·   " Foreground="#FF9BA1AD" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="Esc to cancel" Foreground="#FF9BA1AD" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Magnifier panel that follows the cursor -->
        <Border x:Name="Magnifier"
                Width="180"
                Background="#EE12141A"
                BorderBrush="#FF3DA9FC" BorderThickness="1"
                CornerRadius="10"
                Padding="8"
                IsHitTestVisible="False"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed">
            <StackPanel>
                <!-- Zoomed pixels -->
                <Grid Width="164" Height="164">
                    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4" ClipToBounds="True">
                        <Image x:Name="ZoomImage"
                               Stretch="Fill"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               UseLayoutRounding="True"
                               SnapsToDevicePixels="True"/>
                    </Border>
                    <!-- Center pixel highlight (1 zoomed pixel = 164/11 ≈ 14.9 px) -->
                    <Rectangle Width="15" Height="15"
                               Stroke="#FFFFFFFF" StrokeThickness="1.5"
                               Fill="Transparent"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <Rectangle Width="17" Height="17"
                               Stroke="#FF000000" StrokeThickness="1"
                               Fill="Transparent"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Swatch + hex/rgb readout -->
                <Border x:Name="SwatchBorder"
                        Height="22" CornerRadius="4"
                        Margin="0,8,0,0"
                        BorderBrush="#33FFFFFF" BorderThickness="1"/>
                <TextBlock x:Name="HexText"
                           Text="#000000"
                           Foreground="White"
                           FontFamily="Consolas" FontSize="14"
                           TextAlignment="Center" Margin="0,6,0,0"/>
                <TextBlock x:Name="SubText"
                           Text="rgb(0, 0, 0)"
                           Foreground="#FF9BA1AD"
                           FontFamily="Consolas" FontSize="11"
                           TextAlignment="Center"/>
                <TextBlock x:Name="CoordText"
                           Text="0, 0"
                           Foreground="#FF9BA1AD"
                           FontFamily="Consolas" FontSize="10"
                           TextAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
