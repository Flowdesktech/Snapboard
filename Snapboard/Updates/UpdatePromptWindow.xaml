<Window x:Class="Snapboard.Updates.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapboard update available"
        Icon="../Assets/snapboard.ico"
        Width="540" Height="460"
        MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FF15171C"
        Foreground="#FFE6E8EC"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBg"     Color="#FF1C1F26"/>
        <SolidColorBrush x:Key="CardBorder" Color="#FF2A2E37"/>
        <SolidColorBrush x:Key="Muted"      Color="#FF9BA1AD"/>
        <SolidColorBrush x:Key="Accent"     Color="#FF3DA9FC"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF5BB8FD"/>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Dark progress bar -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#FF0F1218"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="Height" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title + subtitle -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Snapboard update available"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="White"/>
            <TextBlock x:Name="SubtitleText"
                       Margin="0,4,0,0"
                       Foreground="{StaticResource Muted}"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Release notes -->
        <Border Grid.Row="2"
                Margin="0,16,0,0"
                Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Release notes"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Muted}"
                           Margin="16,14,16,4"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,0,16,14">
                    <TextBlock x:Name="ReleaseNotesText"
                               TextWrapping="Wrap"
                               FontSize="12.5"
                               LineHeight="18"
                               Foreground="#FFD7DBE3"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Progress -->
        <StackPanel Grid.Row="3"
                    Margin="0,14,0,0"
                    x:Name="ProgressArea"
                    Visibility="Collapsed">
            <TextBlock x:Name="ProgressLabel"
                       Text="Downloading…"
                       Foreground="{StaticResource Muted}"
                       FontSize="12"
                       Margin="0,0,0,6"/>
            <ProgressBar x:Name="DownloadProgress"
                         Minimum="0" Maximum="1"
                         Value="0"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="4" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    x:Name="SkipButton"
                    Content="Skip this version"
                    Style="{StaticResource GhostButton}"
                    Click="OnSkipClick"/>
            <Button Grid.Column="2"
                    x:Name="LaterButton"
                    Content="Remind me later"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,10,0"
                    Click="OnLaterClick"/>
            <Button Grid.Column="3"
                    x:Name="InstallButton"
                    Content="Download and install"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnInstallClick"
                    IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
