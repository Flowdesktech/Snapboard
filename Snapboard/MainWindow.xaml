<Window x:Class="Snapboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapboard"
        Icon="Assets/snapboard.ico"
        Width="988" Height="693"
        MinWidth="640" MinHeight="880"
        WindowStartupLocation="CenterScreen"
        Background="#FF15171C"
        Foreground="#FFE6E8EC"
        FontFamily="Segoe UI"
        UseLayoutRounding="True">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#FF1C1F26"/>
        <SolidColorBrush x:Key="CardBorder" Color="#FF2A2E37"/>
        <SolidColorBrush x:Key="Muted" Color="#FF9BA1AD"/>
        <SolidColorBrush x:Key="Accent" Color="#FF3DA9FC"/>
        <SolidColorBrush x:Key="AccentHover" Color="#FF5BB8FD"/>
        <SolidColorBrush x:Key="KbdBg" Color="#FF262A33"/>
        <SolidColorBrush x:Key="KbdBorder" Color="#FF3A3F4A"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="Kbd" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource KbdBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource KbdBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <Style x:Key="KbdValue" TargetType="Border" BasedOn="{StaticResource Kbd}">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="KbdText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Mono"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFEAF0F8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2E8DE0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolChip" TargetType="ToggleButton">
            <Setter Property="Background" Value="#FF242831"/>
            <Setter Property="Foreground" Value="#FFE6E8EC"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2D323D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2A3340"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Larger top-right actions in the header -->
        <Style x:Key="HeaderActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FFD3DBEA"/>
            <Setter Property="BorderBrush" Value="#FF343C4C"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="#FF141A25"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                MinHeight="42"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF1B2330"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF4A5D7C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF111722"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShortcutRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ShortcutLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF4F8FF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Slightly smaller hotkey chip used in the Utilities list so
             long subtitles still have room and never collide with chips. -->
        <Style x:Key="UtilityKbdValue" TargetType="Border" BasedOn="{StaticResource Kbd}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="UtilitySubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="65*"/>
            <ColumnDefinition Width="924*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="28,22,28,10" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Snapboard" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="Capture · Annotate · Blur" Foreground="{StaticResource Muted}" FontSize="13" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource HeaderActionButton}" Content="About" Click="OnAboutClick"/>
                <Button Style="{StaticResource HeaderActionButton}" Content="Settings" Click="OnSettingsClick"/>
                <Button Style="{StaticResource HeaderActionButton}" Content="Minimize to tray" Click="OnHideToTrayClick"/>
                <Button Style="{StaticResource HeaderActionButton}" Content="Exit" Click="OnExitClick" Margin="0"/>
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="28,8,28,8" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Hero capture card -->
            <Border Grid.Column="0" Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,155,10">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="QUICK CAPTURE"/>
                    <TextBlock Text="Grab a region of your screen"
                               FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Drag to select an area, then annotate or blur sensitive content before copying or saving."
                               Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButton}" Click="OnCaptureClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📷" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Capture screen" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                            <TextBlock Text="or press" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                            <Border Style="{StaticResource KbdValue}" Margin="6,0,0,0">
                                <TextBlock x:Name="HeroHotkeyText" Text="PrtScn" Style="{StaticResource KbdText}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Secondary capture modes: window picker + scrolling capture.
                         These close the gap with ShareX and Snagit for
                         documentation / support workflows. -->
                    <WrapPanel Margin="0,12,0,0">
                        <Button Style="{StaticResource GhostButton}"
                                Click="OnCaptureWindowClick"
                                Padding="12,8"
                                Margin="0,0,8,8"
                                ToolTip="Pick a window from a visual list and capture just that window.">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗔" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Capture window…" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostButton}"
                                Click="OnScrollingCaptureClick"
                                Padding="12,8"
                                Margin="0,0,8,8"
                                ToolTip="Pick a scrollable region, then scroll normally — Snapboard stitches every frame into a single tall image.">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⇅" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Scrolling capture…" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Shortcuts card -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="489,0,0,10" Grid.ColumnSpan="2">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="SHORTCUTS"/>
                    <StackPanel Margin="0,4,0,0">
                        <Grid Style="{StaticResource ShortcutRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Start capture" Style="{StaticResource ShortcutLabel}"/>
                            <Border Grid.Column="1" Style="{StaticResource KbdValue}">
                                <TextBlock x:Name="ShortcutCaptureText" Text="PrtScn" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource ShortcutRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Copy" Style="{StaticResource ShortcutLabel}"/>
                            <Border Grid.Column="1" Style="{StaticResource KbdValue}">
                                <TextBlock Text="Ctrl + C" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource ShortcutRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Save" Style="{StaticResource ShortcutLabel}"/>
                            <Border Grid.Column="1" Style="{StaticResource KbdValue}">
                                <TextBlock Text="Ctrl + S" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource ShortcutRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Undo" Style="{StaticResource ShortcutLabel}"/>
                            <Border Grid.Column="1" Style="{StaticResource KbdValue}">
                                <TextBlock Text="Ctrl + Z" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>

                        <Grid Style="{StaticResource ShortcutRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cancel" Style="{StaticResource ShortcutLabel}"/>
                            <Border Grid.Column="1" Style="{StaticResource KbdValue}">
                                <TextBlock Text="Esc" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Full-screen save" Style="{StaticResource ShortcutLabel}"/>
                            <Border Grid.Column="1" Style="{StaticResource KbdValue}">
                                <TextBlock x:Name="ShortcutFullScreenText" Text="Ctrl+PrtScn" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Tools card -->
            <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource Card}" Margin="0,10,155,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="TOOLS"/>
                    <WrapPanel x:Name="ToolChipPanel">
                        <ToggleButton Style="{StaticResource ToolChip}" Tag="Pen"   Click="OnToolChipClick" Content="🖊  Pen"/>
                        <ToggleButton Style="{StaticResource ToolChip}" Tag="Rect"  Click="OnToolChipClick" Content="▭  Rect"/>
                        <ToggleButton Style="{StaticResource ToolChip}" Tag="Arrow" Click="OnToolChipClick" Content="➤  Arrow"/>
                        <ToggleButton Style="{StaticResource ToolChip}" Tag="Text"  Click="OnToolChipClick" Content="T  Text"/>
                        <ToggleButton Style="{StaticResource ToolChip}" Tag="Blur"  Click="OnToolChipClick" Content="▓  Blur" IsChecked="True"/>
                    </WrapPanel>
                    <TextBlock x:Name="ToolDescriptionText"
                               Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0"
                               Text="The Blur tool masks any rectangle you drag over it — useful for passwords, emails, tokens and other sensitive content before sharing a screenshot."/>
                    <TextBlock Foreground="#FF6B7280" FontSize="11" Margin="0,8,0,0"
                               Text="Pick a tool here to preview it, then press your Capture hotkey to start annotating."/>
                </StackPanel>
            </Border>

            <!-- Utilities card -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="489,10,0,0" Grid.ColumnSpan="2">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="UTILITIES"/>

                    <Button Style="{StaticResource GhostButton}"
                            Click="OnColorPickerClick"
                            HorizontalContentAlignment="Stretch"
                            Padding="12,10"
                            MinHeight="72"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🎨" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="Color picker" Foreground="#FFE6E8EC" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Eyedropper with pixel magnifier" Style="{StaticResource UtilitySubtitle}"/>
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource UtilityKbdValue}" VerticalAlignment="Center">
                                <TextBlock x:Name="ShortcutColorPickerText" Text="—" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource GhostButton}"
                            Click="OnOcrClick"
                            HorizontalContentAlignment="Stretch"
                            Padding="12,10"
                            MinHeight="72"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔤" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="OCR on selection" Foreground="#FFE6E8EC" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Extract text from a region of the screen" Style="{StaticResource UtilitySubtitle}"/>
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource UtilityKbdValue}" VerticalAlignment="Center">
                                <TextBlock x:Name="ShortcutOcrText" Text="—" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource GhostButton}"
                            Click="OnQrClick"
                            HorizontalContentAlignment="Stretch"
                            Padding="12,10"
                            MinHeight="72"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x25A3;" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="Scan QR code" Foreground="#FFE6E8EC" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Decode QR · data matrix · barcodes from any selection" Style="{StaticResource UtilitySubtitle}"/>
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource UtilityKbdValue}" VerticalAlignment="Center">
                                <TextBlock x:Name="ShortcutQrText" Text="—" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource GhostButton}"
                            Click="OnRulerClick"
                            HorizontalContentAlignment="Stretch"
                            Padding="12,10"
                            MinHeight="72">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📏" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="Pixel ruler" Foreground="#FFE6E8EC" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Floating ruler · H/V toggle · topmost" Style="{StaticResource UtilitySubtitle}"/>
                            </StackPanel>
                            <Border Grid.Column="2" Style="{StaticResource UtilityKbdValue}" VerticalAlignment="Center">
                                <TextBlock x:Name="ShortcutRulerText" Text="—" Style="{StaticResource KbdText}"/>
                            </Border>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#FF12141A" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,1,0,0" Padding="28,10" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="{StaticResource Muted}" FontSize="12"
                           VerticalAlignment="Center">
                    <Run Text="© 2026 "/><Hyperlink NavigateUri="https://flowdesk.tech"
                                                    RequestNavigate="OnFooterLinkClick"
                                                    Foreground="{StaticResource Accent}"
                                                    TextDecorations="None">FlowDesk</Hyperlink><Run Text=" · Snapboard · Local · No uploads · "/><Run x:Name="FooterVersionRun" Text="v0.0.0"/>
                </TextBlock>
                <TextBlock Grid.Column="2" x:Name="HotkeyStatusText"
                           Foreground="{StaticResource Muted}" FontSize="12"
                           Text="PrtScn hotkey registered" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
