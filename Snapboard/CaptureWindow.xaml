<Window x:Class="Snapboard.CaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapboard Capture"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        PreviewKeyDown="OnPreviewKeyDown"
        KeyDown="OnKeyDown"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        Loaded="OnLoaded">
    <Window.Resources>
        <!-- Compact Lightshot-style square icon button for the vertical rail. -->
        <Style x:Key="IconToolToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ToolFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconToolButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ToolFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon-only square button for the horizontal action bar (matches
             Lightshot: compact glyphs, no labels). -->
        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource IconToolButton}">
            <Setter Property="Margin" Value="1,0"/>
        </Style>

        <!-- Slim horizontal divider used between groups in the vertical rail. -->
        <Style x:Key="RailDivider" TargetType="Rectangle">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="3,3,3,3"/>
            <Setter Property="Fill" Value="#33FFFFFF"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" ClipToBounds="True">
        <!-- The full-screen screenshot sits beneath everything -->
        <Image x:Name="BackgroundImage" Stretch="Fill" SnapsToDevicePixels="True"/>

        <!-- 4 dim rectangles form a "hole" around the selection -->
        <Canvas x:Name="DimCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="DimTop"    Fill="#99000000"/>
            <Rectangle x:Name="DimBottom" Fill="#99000000"/>
            <Rectangle x:Name="DimLeft"   Fill="#99000000"/>
            <Rectangle x:Name="DimRight"  Fill="#99000000"/>
        </Canvas>

        <!-- Annotations live on this canvas and are clipped to the selection -->
        <Canvas x:Name="AnnotationCanvas" IsHitTestVisible="False"/>

        <!-- Live preview shape while drawing (rectangles / arrows / blur preview) -->
        <Canvas x:Name="PreviewCanvas" IsHitTestVisible="False"/>

        <!-- Selection border -->
        <Rectangle x:Name="SelectionBorder"
                   Stroke="#FF3DA9FC" StrokeThickness="1.5"
                   Fill="Transparent"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"
                   HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <!-- 8 corner/midpoint selection handles, Lightshot-style. -->
        <Canvas x:Name="HandleCanvas" IsHitTestVisible="False"/>

        <!-- Size label above the selection -->
        <Border x:Name="SizeLabel"
                Background="#CC101114" CornerRadius="3" Padding="6,2"
                IsHitTestVisible="False"
                Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" FontFamily="Segoe UI"/>
        </Border>

        <!-- =========================== VERTICAL TOOL RAIL ===========================
             Attached to the right edge of the selection. Lightshot-style:
             compact, icon-only. -->
        <Border x:Name="VToolbar"
                Background="{StaticResource ToolbarBg}"
                BorderBrush="{StaticResource ToolbarBorder}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="2"
                Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="2" Opacity="0.45"/>
            </Border.Effect>
            <StackPanel Orientation="Vertical">
                <ToggleButton x:Name="ToolPen"   Style="{StaticResource IconToolToggle}" Tag="Pen"   Click="OnToolSelected" ToolTip="Pen"        Content="&#xE70F;"/>
                <ToggleButton x:Name="ToolArrow" Style="{StaticResource IconToolToggle}" Tag="Arrow" Click="OnToolSelected" ToolTip="Arrow"      Content="&#xF0AF;"/>
                <ToggleButton x:Name="ToolRect"  Style="{StaticResource IconToolToggle}" Tag="Rect"  Click="OnToolSelected" ToolTip="Rectangle"  Content="&#xE739;"/>
                <ToggleButton x:Name="ToolBlur"  Style="{StaticResource IconToolToggle}" Tag="Blur"  Click="OnToolSelected" ToolTip="Blur"       Content="&#xE81E;"/>
                <ToggleButton x:Name="ToolText"  Style="{StaticResource IconToolToggle}" Tag="Text"  Click="OnToolSelected" ToolTip="Text">
                    <TextBlock Text="T" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="13"/>
                </ToggleButton>

                <Rectangle Style="{StaticResource RailDivider}"/>

                <!-- Color swatch (square, matches Lightshot). Click → palette popup. -->
                <Button x:Name="ColorButton" Style="{StaticResource IconToolButton}" Click="OnColorButtonClick" ToolTip="Color">
                    <Border x:Name="ColorSwatch" Width="16" Height="16" CornerRadius="2"
                            Background="#FFEF4444"
                            BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                </Button>

                <!-- Size: shows current thickness; click opens the thickness popup. -->
                <Button x:Name="SizeButton" Style="{StaticResource IconToolButton}" Click="OnSizeButtonClick" ToolTip="Thickness">
                    <Ellipse x:Name="SizeSwatch" Width="9" Height="9" Fill="White"/>
                </Button>

                <Rectangle Style="{StaticResource RailDivider}"/>

                <Button Style="{StaticResource IconToolButton}" Click="OnUndoClick" ToolTip="Undo (Ctrl+Z)" Content="&#xE7A7;"/>
            </StackPanel>
        </Border>

        <!-- Color palette popup, floats to the left of the color button. -->
        <Popup x:Name="ColorPopup" AllowsTransparency="True" StaysOpen="False"
               Placement="Left" HorizontalOffset="-6" VerticalOffset="0"
               PlacementTarget="{Binding ElementName=ColorButton}"
               PopupAnimation="None">
            <Border Background="{StaticResource ToolbarBg}"
                    BorderBrush="{StaticResource ToolbarBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="4">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="2" Opacity="0.55"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IconToolButton}" Click="OnColorClick" Tag="#FFEF4444" ToolTip="Red">
                        <Border Width="18" Height="18" CornerRadius="9" Background="#FFEF4444" BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnColorClick" Tag="#FFF59E0B" ToolTip="Orange">
                        <Border Width="18" Height="18" CornerRadius="9" Background="#FFF59E0B" BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnColorClick" Tag="#FFFACC15" ToolTip="Yellow">
                        <Border Width="18" Height="18" CornerRadius="9" Background="#FFFACC15" BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnColorClick" Tag="#FF10B981" ToolTip="Green">
                        <Border Width="18" Height="18" CornerRadius="9" Background="#FF10B981" BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnColorClick" Tag="#FF3DA9FC" ToolTip="Blue">
                        <Border Width="18" Height="18" CornerRadius="9" Background="#FF3DA9FC" BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnColorClick" Tag="#FFA855F7" ToolTip="Purple">
                        <Border Width="18" Height="18" CornerRadius="9" Background="#FFA855F7" BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnColorClick" Tag="#FFFFFFFF" ToolTip="White">
                        <Border Width="18" Height="18" CornerRadius="9" Background="White" BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnColorClick" Tag="#FF111827" ToolTip="Black">
                        <Border Width="18" Height="18" CornerRadius="9" Background="#FF111827" BorderBrush="#AAFFFFFF" BorderThickness="1"/>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Thickness popup -->
        <Popup x:Name="SizePopup" AllowsTransparency="True" StaysOpen="False"
               Placement="Left" HorizontalOffset="-6" VerticalOffset="0"
               PlacementTarget="{Binding ElementName=SizeButton}"
               PopupAnimation="None">
            <Border Background="{StaticResource ToolbarBg}"
                    BorderBrush="{StaticResource ToolbarBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="4">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="2" Opacity="0.55"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IconToolButton}" Click="OnThicknessClick" Tag="2" ToolTip="Thin">
                        <Ellipse Width="5" Height="5" Fill="White"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnThicknessClick" Tag="4" ToolTip="Medium">
                        <Ellipse Width="9" Height="9" Fill="White"/>
                    </Button>
                    <Button Style="{StaticResource IconToolButton}" Click="OnThicknessClick" Tag="8" ToolTip="Thick">
                        <Ellipse Width="14" Height="14" Fill="White"/>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <!-- =========================== HORIZONTAL ACTION BAR =========================
             Below the selection, right-aligned. Icon-only, Lightshot-style. -->
        <Border x:Name="HToolbar"
                Background="{StaticResource ToolbarBg}"
                BorderBrush="{StaticResource ToolbarBorder}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="2"
                Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="2" Opacity="0.45"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <!-- Pin to screen: floating always-on-top pin of the captured
                     region. Big differentiator vs ShareX (which lacks this). -->
                <Button Style="{StaticResource ActionButton}" Click="OnPinClick"   ToolTip="Pin to screen (stays on top)"  Content="&#xE718;"/>
                <!-- Reverse image search: Google Images / Bing Visual Search.
                     We upload the bitmap directly to the engine — no third
                     party host. -->
                <Button Style="{StaticResource ActionButton}" Click="OnGoogleSearchClick" ToolTip="Search image on Google"     Content="&#xE721;"/>
                <Button Style="{StaticResource ActionButton}" Click="OnBingSearchClick"   ToolTip="Search image on Bing Visual Search" Content="&#xF6FA;"/>
                <Rectangle Width="1" Margin="3,4" Fill="#33FFFFFF"/>
                <Button Style="{StaticResource ActionButton}" Click="OnPrintClick" ToolTip="Print"                 Content="&#xE749;"/>
                <Button Style="{StaticResource ActionButton}" Click="OnCopyClick"  ToolTip="Copy to clipboard (Enter)" Content="&#xE8C8;"/>
                <Button Style="{StaticResource ActionButton}" Click="OnSaveClick"  ToolTip="Save to file (Ctrl+S)"    Content="&#xE74E;"/>
                <Button Style="{StaticResource ActionButton}" Click="OnCloseClick" ToolTip="Close (Esc)"              Content="&#xE8BB;"/>
            </StackPanel>
        </Border>

        <!-- Floating hint that follows the cursor (Lightshot-style) -->
        <Border x:Name="CursorHint"
                Background="#EE12141A"
                BorderBrush="#FF3DA9FC" BorderThickness="1"
                CornerRadius="6" Padding="10,6"
                IsHitTestVisible="False"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#FF3DA9FC" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Select an area" Foreground="White" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <TextBlock Text="   ·   " Foreground="#FF9BA1AD" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="Esc to cancel" Foreground="#FF9BA1AD" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
