<Window x:Class="Snapboard.Qr.QrSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapboard QR scan"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Focusable="True"
        PreviewKeyDown="OnPreviewKeyDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseLeftButtonUp="OnMouseLeftButtonUp"
        Loaded="OnLoaded">
    <Grid x:Name="RootGrid" ClipToBounds="True">
        <Image x:Name="BackgroundImage" Stretch="Fill" SnapsToDevicePixels="True"/>

        <Canvas x:Name="DimCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="DimTop"    Fill="#99000000"/>
            <Rectangle x:Name="DimBottom" Fill="#99000000"/>
            <Rectangle x:Name="DimLeft"   Fill="#99000000"/>
            <Rectangle x:Name="DimRight"  Fill="#99000000"/>
        </Canvas>

        <Rectangle x:Name="SelectionBorder"
                   Stroke="#FF8B5CF6" StrokeThickness="1.5"
                   Fill="Transparent"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"
                   HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <Border x:Name="SizeLabel"
                Background="#CC101114" CornerRadius="3" Padding="6,2"
                IsHitTestVisible="False"
                Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" FontFamily="Segoe UI"/>
        </Border>

        <Border x:Name="CursorHint"
                Background="#EE12141A"
                BorderBrush="#FF8B5CF6" BorderThickness="1"
                CornerRadius="6" Padding="10,6"
                IsHitTestVisible="False"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x25A3;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"
                           Foreground="#FFC4B5FD"/>
                <TextBlock Text="Draw a rectangle around the QR code"
                           Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="   ·   " Foreground="#FF9BA1AD" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="Esc to cancel" Foreground="#FF9BA1AD" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
